We calculate the Uncertainty Penalty to ensure RADAR's automation doesn't trigger on low-confidence data.

import math

def shannon_entropy(probs):
    return -sum(p * math.log2(p) for p in probs if p > 0)

# Scenario A: High Confidence (Tag is definitely on Shelf 1)
probs_a = [0.95, 0.05] 
# Scenario B: High Chaos (Tag could be anywhere)
probs_b = [0.5, 0.5]

print(f"Entropy A (Signal): {shannon_entropy(probs_a):.4f} bits")
print(f"Entropy B (Noise):  {shannon_entropy(probs_b):.4f} bits")


